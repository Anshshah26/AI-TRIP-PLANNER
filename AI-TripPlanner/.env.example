# Server Configuration
PORT=5000
NODE_ENV=development

# Database (MongoDB)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/ai-trip-planner

# Application URLs
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Authentication (JWT) - Generate strong secrets for production!
JWT_ACCESS_SECRET=change_this_to_a_strong_random_secret_for_production
JWT_REFRESH_SECRET=change_this_to_a_strong_random_secret_for_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=change_this_to_a_strong_random_secret_for_production

# Email Service (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=AI Trip Planner <noreply@yourdomain.com>

# AI Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Client Environment Variables (for Vercel .env.local)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Logging
LOG_LEVEL=info
